# Local development: set true to use Docker Postgres (DB_*) instead of DATABASE_URL
USE_LOCAL_DATABASE=true

# Cloud database (Supabase) — used when USE_LOCAL_DATABASE is not true, or for cloud migrations
# DATABASE_URL=postgresql://user:password@host:6543/postgres

# Local Docker Postgres (matches docker-compose.yml)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=ranch_owner
DB_PASSWORD=stable_crypto_pass123
DB_NAME=stablehands

# Redis (Docker)
REDIS_HOST=localhost
REDIS_PORT=6379

# Backend
NODE_ENV=development
PORT=3000
JWT_SECRET=change-me-for-local-dev

# Email (optional — password reset flows)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# Firebase Admin (optional — push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional stable timezone override
# STABLE_TIMEZONE=Asia/Jerusalem
