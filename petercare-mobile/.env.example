# Production (Render)
# EXPO_PUBLIC_API_URL=https://petercare.onrender.com

# Local dev — pick the URL that matches how you run the app:
#
# iOS/Android simulator or Expo web on this PC:
#   EXPO_PUBLIC_API_URL=http://localhost:3000
#
# Physical phone (Expo Go) on the same Wi‑Fi — use your PC's LAN IP, not localhost.
# Run `npm run print:lan-ip` or `ipconfig` (Windows) to find your IPv4 address:
#   EXPO_PUBLIC_API_URL=http://192.168.1.42:3000
#
EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:3000

# Firebase Web Push only (from Firebase Console → Project settings → Web app).
# These env vars are NOT used for Android native push — Android requires
# google-services.json in the project root and FCM V1 credentials in EAS.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_VAPID_KEY=

# Android native push: copy your Firebase download to google-services.json
# (see google-services.json.example), or upload via:
#   eas env:create --name GOOGLE_SERVICES_JSON --type file --value ./google-services.json
